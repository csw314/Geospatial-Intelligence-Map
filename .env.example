# Optional: override the basemap tile source.
# Default uses CARTO Voyager raster tiles for English/Latin-friendly labels.
# GLOBAL_LOCATION_TILE_LAYER_NAME=CARTO Voyager
# GLOBAL_LOCATION_TILE_URL=https://{s}.basemaps.cartocdn.com/rastertiles/voyager/{z}/{x}/{y}.png
# GLOBAL_LOCATION_TILE_ATTRIBUTION=&copy; <a href="https://www.openstreetmap.org/copyright">OpenStreetMap</a> contributors &copy; <a href="https://carto.com/attributions">CARTO</a>

# Optional local Dash debug mode.
DASH_DEBUG=false
